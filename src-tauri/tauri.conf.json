{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ipmsg-tauri",
  "version": "0.1.0",
  "identifier": "me.langzi.ipmsg",
  "build": {
    "beforeDevCommand": "dx serve --port 1421 --interactive false",
    "devUrl": "http://localhost:1421",
    "beforeBuildCommand": "dx bundle --release",
    "frontendDist": "../dist/public"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "ipmsg-tauri",
        "width": 800,
        "height": 600,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true
      }
    ],
    "macOSPrivateApi": true,
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
